{
  "name"              : "valkyrja/rector",
  "type"              : "project",
  "description"       : "Rector for the Valkyrja Project.",
  "homepage"          : "https://www.valkyrja.io/",
  "keywords"          : [
    "ci",
    "rector",
    "valkyrja"
  ],
  "license"           : "MIT",
  "authors"           : [
    {
      "name"  : "Melech Mizrachi",
      "email" : "melechmizrachi@gmail.com"
    }
  ],
  "require"           : {
    "php"           : ">=8.4",
    "rector/rector" : "^2.3.9"
  },
  "autoload"          : {
    "psr-4" : {
      "Valkyrja\\Rector\\" : "src/Rector"
    }
  },
  "autoload-dev"      : {
    "psr-4" : {
      "Valkyrja\\Rector\\Tests\\" : "tests/Tests"
    }
  },
  "minimum-stability" : "dev",
  "prefer-stable"     : true
}
